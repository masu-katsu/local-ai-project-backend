# ============================================
# ローカルAI統合システム - 環境変数設定
# ============================================
# このファイルを .env にリネームして使用してください

# FastAPI設定
FASTAPI_PORT=8000
API_KEY=your-secret-key-here

# AIモデルURL
PHI3_URL=http://phi3:8001
QWEN_URL=http://qwen:8002

# Redis設定
REDIS_URL=redis://redis:6379

# ChromaDB設定
CHROMA_HOST=chromadb
CHROMA_PORT=8003

# Mem0設定
MEM0_URL=http://mem0:8080

# LangGraph設定
LANGGRAPH_URL=http://langgraph:8081

# SearxNG設定
SEARXNG_URL=http://searxng:8080

# Whisper設定
WHISPER_URL=http://whisper:8000

# Piper設定
PIPER_URL=http://piper:8000

# MCP設定
MCP_URL=http://mcp-server:3000

# Phi3設定
PHI3_MAX_TOKENS=512
PHI3_THREADS=4

# Qwen設定
QWEN_MAX_TOKENS=2048

# ログレベル
LOG_LEVEL=INFO
