# ============================================
# ローカルAI統合システム - 環境変数設定
# ============================================
# このファイルを .env にリネームして使用してください

# FastAPI設定
FASTAPI_PORT=8000
API_KEY=your-secret-key-here

# Phi3設定
PHI3_MAX_TOKENS=512
PHI3_THREADS=4

# Qwen設定
QWEN_MAX_TOKENS=2048

# ログレベル
LOG_LEVEL=INFO
